{
  "name": "@zakati/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "preview": "pnpm pages:build && wrangler pages dev .vercel/output/static --compatibility-flag nodejs_compat",
    "deploy": "pnpm pages:build && wrangler pages deploy .vercel/output/static --project-name zakati --branch main",
    "deploy:preview": "pnpm pages:build && wrangler pages deploy .vercel/output/static --project-name zakati --branch preview"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "@zakati/engine": "workspace:*",
    "@zakati/document-pipeline": "workspace:*",
    "zustand": "^5.0.1",
    "immer": "^10.1.1",
    "framer-motion": "^11.11.17",
    "vaul": "^1.1.1",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.0",
    "@sanity/client": "^6.22.5",
    "@sanity/image-url": "^1.0.2",
    "@react-pdf/renderer": "^4.1.5",
    "nanoid": "^5.0.8",
    "date-fns": "^4.1.0",
    "react-hook-form": "^7.53.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@cloudflare/next-on-pages": "^1.13.7",
    "@cloudflare/workers-types": "^4.20241112.0",
    "wrangler": "^3.86.0",
    "vercel": "^39.0.0",
    "typescript": "^5.6.3",
    "tailwindcss": "4.0.0-beta.3",
    "@tailwindcss/postcss": "4.0.0-beta.3",
    "postcss": "^8.4.49",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.3"
  }
}
